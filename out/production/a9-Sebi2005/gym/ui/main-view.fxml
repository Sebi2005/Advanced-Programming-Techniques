<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gym.ui.MainController">
    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>

            </padding>
            <Button fx:id="buttonUndo" text="Undo" onAction="#onUndo"/>
            <Button fx:id="buttonRedo" text="Redo" onAction="#onRedo"/>

            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="labelStatus" text=""/>
        </HBox>
    </top>
    <center>
        <TabPane>
            <Tab text="Clients" closable="false">
                <BorderPane>
                    <top>
                        <HBox spacing="10">
                            <padding>
                                <Insets top="10" right="10" bottom="10" left="10"/>
                            </padding>
                            <Label text="Filter name:"/>
                            <TextField fx:id="textFieldClientFilterName" promptText="contains..."/>

                            <Label text="Filter email:"/>
                            <TextField fx:id="textFieldClientFilterEmail" promptText="contains..."/>

                            <Button text="Clear filters" onAction="#onClearClientFilters"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Refresh" onAction="#onRefreshClients"/>
                        </HBox>
                    </top>

                    <center>
                        <TableView fx:id="clientTableView">
                            <columns>
                                <TableColumn fx:id="columnClientId" text="ID" prefWidth="80"/>
                                <TableColumn fx:id="columnClientName" text="Name" prefWidth="180"/>
                                <TableColumn fx:id="columnClientEmail" text="Email" prefWidth="220"/>
                                <TableColumn fx:id="columnClientPhone" text="Phone" prefWidth="140"/>
                            </columns>
                        </TableView>
                    </center>

                    <bottom>
                        <GridPane hgap="10" vgap="10">
                            <padding>
                                <Insets top="10" right="10" bottom="10" left="10"/>
                            </padding>
                            <columnConstraints>
                                <ColumnConstraints percentWidth="15"/>
                                <ColumnConstraints percentWidth="35"/>
                                <ColumnConstraints percentWidth="15"/>
                                <ColumnConstraints percentWidth="35"/>
                            </columnConstraints>

                            <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="textFieldClientId" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="e.g. 1"/>

                            <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="textFieldClientName" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="textFieldClientEmail" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Phone:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="textFieldClientPhone" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="4">
                                <Button text="Add" onAction="#onAddClient"/>
                                <Button text="Update" onAction="#onUpdateClient"/>
                                <Button text="Delete" onAction="#onDeleteClient"/>
                                <Button text="Clear" onAction="#onClearClientForm"/>
                            </HBox>
                        </GridPane>
                    </bottom>
                </BorderPane>
            </Tab>


            <Tab text="Sessions" closable="false">
                <BorderPane>
                    <top>
                        <HBox spacing="10">
                            <padding>
                                <Insets top="10" right="10" bottom="10" left="10"/>
                            </padding>
                            <Label text="Filter clientId:"/>
                            <TextField fx:id="textFieldSessionFilterClientId" promptText="e.g. 1"/>

                            <Label text="Filter date:"/>
                            <DatePicker fx:id="datePickerSessionFilterDate"/>

                            <Button text="Apply filters" onAction="#onApplySessionFilters"/>
                            <Button text="Clear filters" onAction="#onClearSessionFilters"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Refresh" onAction="#onRefreshSessions"/>
                        </HBox>
                    </top>

                    <center>
                        <TableView fx:id="sessionTableView">
                            <columns>
                                <TableColumn fx:id="columnSessionId" text="ID" prefWidth="70"/>
                                <TableColumn fx:id="columnSessionClientId" text="Client ID" prefWidth="90"/>
                                <TableColumn fx:id="columnSessionDateTime" text="DateTime" prefWidth="180"/>
                                <TableColumn fx:id="columnSessionDescription" text="Description" prefWidth="300"/>
                            </columns>
                        </TableView>
                    </center>

                    <bottom>
                        <GridPane hgap="10" vgap="10">
                            <padding>
                                <Insets top="10" right="10" bottom="10" left="10"/>
                            </padding>
                            <columnConstraints>
                                <ColumnConstraints percentWidth="15"/>
                                <ColumnConstraints percentWidth="35"/>
                                <ColumnConstraints percentWidth="15"/>
                                <ColumnConstraints percentWidth="35"/>
                            </columnConstraints>

                            <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="textFieldSessionId" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Client ID:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="textFieldSessionClientId" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Date:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <DatePicker fx:id="datePickerSessionDate" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Time (HH:mm):" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="textFieldSessionTime" GridPane.rowIndex="1" GridPane.columnIndex="3" promptText="e.g. 14:30"/>

                            <Label text="Description:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextArea fx:id="textAreaSessionDesc" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"
                                      prefRowCount="2"/>

                            <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4">
                                <Button text="Add" onAction="#onAddSession"/>
                                <Button text="Update" onAction="#onUpdateSession"/>
                                <Button text="Delete" onAction="#onDeleteSession"/>
                                <Button text="Clear" onAction="#onClearSessionForm"/>
                            </HBox>
                        </GridPane>
                    </bottom>
                </BorderPane>
            </Tab>


            <Tab text="Reports" closable="false">
                <BorderPane>
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <top>
                        <VBox spacing="10">
                            <Label text="Reports"/>

                            <HBox spacing="10">
                                <Label text="Client ID:"/>
                                <TextField fx:id="textFieldReportClientId" promptText="e.g. 1"/>
                                <Label text="Start:"/>
                                <DatePicker fx:id="datePickerReportStart"/>
                                <Label text="End:"/>
                                <DatePicker fx:id="datePickerReportEnd"/>
                                <Button text="Sessions between dates" onAction="#onReportBetweenDates"/>
                            </HBox>

                            <HBox spacing="10">
                                <Label text="Client ID:"/>
                                <TextField fx:id="textFieldReportClientId2" promptText="e.g. 1"/>
                                <Label text="Keyword:"/>
                                <TextField fx:id="textFieldReportKeyword" promptText="e.g. cardio"/>
                                <Button text="Sessions with keyword" onAction="#onReportWithKeyword"/>
                            </HBox>

                            <HBox spacing="10">
                                <Button text="Session count per client" onAction="#onReportCountPerClient"/>
                                <Button text="Next upcoming session per client" onAction="#onReportNextUpcoming"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Clear output" onAction="#onClearReportOutput"/>
                            </HBox>

                            <HBox spacing="10">
                                <Label text="Client ID:"/>
                                <TextField fx:id="textFieldReportClientId3" promptText="e.g. 1"/>
                                <Button text="Sessions by day for client" onAction="#onReportSessionsByDay"/>
                            </HBox>
                        </VBox>
                    </top>

                    <center>
                        <TextArea fx:id="textAreaReportOutput" editable="false" wrapText="true"/>
                    </center>
                </BorderPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>

